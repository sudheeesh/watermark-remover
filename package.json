{
  "name": "watermark-remover",
  "version": "1.0.0",
  "private": true,
  "description": "Local React + Node watermark remover (ffmpeg-powered).",
  "scripts": {
    "install:all": "npm --prefix backend install && npm --prefix frontend install",
    "backend": "npm --prefix backend start",
    "frontend": "npm --prefix frontend run dev",
    "dev": "concurrently -n api,web -c cyan,green \"npm:backend\" \"npm:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
